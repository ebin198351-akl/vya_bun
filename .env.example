# Vya's Kitchen — environment template
# Copy to .env and fill in. NEVER commit .env to git.

# --- Existing: Gmail SMTP ---
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
ORDER_NOTIFY_EMAIL=yawen4092@gmail.com   # where order copies are sent (you)

# --- Flask ---
FLASK_SECRET=change-this-to-a-long-random-string
ADMIN_PASSWORD=change-me                 # for /admin login
PORT=8000
KITCHEN_TZ=Pacific/Auckland

# --- Kitchen origin (used for distance calc) ---
KITCHEN_ADDRESS=Laurina Road, Sunnynook, Auckland 0620, New Zealand
KITCHEN_LAT=-36.7539
KITCHEN_LNG=174.7449

# --- Stripe (P3) ---
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=nzd

# --- Twilio (P4) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM=VyaKitchen   # alphanumeric sender (NZ one-way SMS, no number purchase)

# --- Google Maps (optional; if blank, falls back to manual region picker) ---
GOOGLE_MAPS_API_KEY=
